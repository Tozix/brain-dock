// brain-dock — Prisma schema (Phase 1 / Foundation).
// Prisma 7: new `prisma-client` generator with explicit output + Bun runtime target,
// JS driver adapters (no native binaryTargets). See docs/plans/001-foundation.md.

generator client {
  provider = "prisma-client"
  output   = "../packages/db/src/generated"
  runtime  = "bun"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum MemoryType {
  DECISION
  FACT
  NOTE
  TODO
}

enum KnowledgeType {
  BUSINESS_RULE
  ARCHITECTURE
  REQUIREMENT
  ADR
  FAQ
  RESEARCH
  NOTE
}

enum DocFormat {
  MD
  TXT
  MDX
  JSON
  YAML
  PDF
  DOCX
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(USER)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  projects  Project[]
  apiKeys   ApiKey[]
  auditLogs AuditLog[]

  @@map("users")
}

model Project {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  ownerId     String   @map("owner_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  owner        User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  repositories Repository[]

  @@index([ownerId])
  @@map("projects")
}

model Repository {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String   @map("project_id") @db.Uuid
  name          String
  // Human-readable, stable handle used for vector filtering (unique within a project).
  alias         String
  // Path to the repository root, as seen by the indexing workers.
  root          String
  defaultBranch String?  @map("default_branch")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, alias])
  @@index([projectId])
  @@map("repositories")
}

model ApiKey {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  description String?
  prefix      String // human-visible identifier, not secret
  keyHash     String       @unique @map("key_hash") // sha256 of the full secret key
  status      ApiKeyStatus @default(ACTIVE)
  userId      String       @map("user_id") @db.Uuid
  rateLimit   Int?         @map("rate_limit")
  expiresAt   DateTime?    @map("expires_at")
  lastUsedAt  DateTime?    @map("last_used_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

model MemoryItem {
  id        String     @id @default(uuid()) @db.Uuid
  projectId String     @map("project_id")
  type      MemoryType @default(NOTE)
  content   String
  tags      String[]
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@index([projectId])
  @@map("memory_items")
}

model KnowledgeItem {
  id        String        @id @default(uuid()) @db.Uuid
  projectId String        @map("project_id")
  type      KnowledgeType @default(NOTE)
  title     String
  content   String
  tags      String[]
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@index([projectId])
  @@map("knowledge_items")
}

model Document {
  id        String    @id @default(uuid()) @db.Uuid
  projectId String    @map("project_id")
  title     String
  format    DocFormat @default(MD)
  source    String?
  content   String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([projectId])
  @@map("documents")
}

// Server-side structural index (so the hosted MCP can serve find_*/architecture/graph without the
// user's files). Populated by the index worker; scoped by project + repo alias; replaced per repo.
model CodeSymbol {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  repo      String
  name      String
  kind      String
  role      String
  file      String
  startLine Int      @map("start_line")
  endLine   Int      @map("end_line")
  // RouteInfo[] for controllers (method/path/handler); null otherwise.
  routes    Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([projectId, repo])
  @@index([projectId, role])
  @@index([projectId, name])
  @@map("code_symbols")
}

model CodeEdge {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  repo      String
  fromName  String   @map("from_name")
  toName    String   @map("to_name")
  // injects | extends | implements | imports
  kind      String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([projectId, repo])
  @@index([projectId, fromName])
  @@index([projectId, toName])
  @@map("code_edges")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@map("audit_logs")
}

// Per-user, per-day MCP usage rollup (calls + approximate tokens served). Written by the remote MCP
// after each tool call; read by the API (`GET /usage`) to power the extension's Token Savings panel.
model McpUsageDaily {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  day          DateTime @db.Date
  calls        Int      @default(0)
  tokensServed Int      @default(0) @map("tokens_served")

  @@unique([userId, day])
  @@index([userId])
  @@map("mcp_usage_daily")
}
