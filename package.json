{
  "name": "@brain-dock/root",
  "version": "0.0.0",
  "private": true,
  "description": "brain-dock — AI Knowledge Platform & MCP Server (local-first)",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "bun test",
    "ci": "bun run db:generate && biome check . && turbo run typecheck && bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "infra:up": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "dev:stack": "bash scripts/dev-stack.sh",
    "search:eval": "bun run packages/search/eval/eval.ts",
    "deploy": "docker compose --profile app up -d --build",
    "backup": "bash scripts/backup.sh"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.5",
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "^1.3.14",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3"
  }
}
