# brain-dock — environment template. Copy to .env and adjust. Validated by Zod at boot.
#
# PRODUCTION-FIRST (all-Docker server deploy). The app containers read this via env_file and reach
# infra over the internal Docker network (postgres/redis/qdrant/ollama) — the URLs below already
# use those DNS names. On the server you only MUST set the JWT secrets and the Postgres password.
#
# LOCAL DEV (services run from source via bun on the host) — flip these:
#   1) NODE_ENV=development
#   2) uncomment the `# dev:` URL lines (localhost host ports, published by docker-compose.dev.yml)
#   3) EMBEDDER=deterministic   (offline, no model needed)
# (NODE_ENV and the infra URLs are overridden by docker-compose on the server, so their value here
#  only affects the bun-on-host dev path.)

# Runtime
NODE_ENV=production
API_PORT=3100
LOG_LEVEL=info

# Bring up the FULL app stack with a bare `docker compose up -d --build` (no `--profile app` flag).
# Leave COMMENTED for local dev — otherwise `bun run infra:up` would also start the app services.
# COMPOSE_PROFILES=app

# --- Auth — REPLACE these in production. The API REFUSES to boot under NODE_ENV=production with the
#     default/short secrets. Generate strong ones: `openssl rand -base64 48`. ---
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- PostgreSQL ---
# Credentials for the postgres container + the in-network DATABASE_URL of app services.
POSTGRES_USER=brain_dock
POSTGRES_PASSWORD=brain_dock          # CHANGE THE PASSWORD for any real deployment
POSTGRES_DB=brain_dock
DATABASE_URL=postgresql://brain_dock:brain_dock@postgres:5432/brain_dock?schema=public
# dev: DATABASE_URL=postgresql://brain_dock:brain_dock@localhost:15432/brain_dock?schema=public

# --- Redis (BullMQ) ---
REDIS_URL=redis://redis:6379
# dev: REDIS_URL=redis://localhost:16379

# --- Qdrant ---
QDRANT_URL=http://qdrant:6333
# dev: QDRANT_URL=http://localhost:16333

# --- Ollama (embeddings) ---
OLLAMA_URL=http://ollama:11434
# dev: OLLAMA_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
# Embedding provider — MUST be consistent across API/MCP/workers writing the same collections.
# `ollama` = real semantic search (pull the model). `deterministic` = offline/fast, for dev only.
EMBEDDER=ollama

# --- Local stdio MCP (apps/mcp/src/index.ts) — single-repo dev only; unused by the hosted HTTP MCP ---
PROJECT_ID=default
PROJECT_ROOT=.
COLLECTION=code
# Multi-repo (optional): JSON array of {alias, root}. When set, overrides the single PROJECT_ROOT.
# REPOS=[{"alias":"api","root":"./apps/api"},{"alias":"web","root":"./apps/web"}]

# --- Hosted MCP over HTTP (apps/mcp/src/http.ts) ---
MCP_HTTP_PORT=8080
# Per-API-key rate limit on the MCP endpoint (fixed window). A key's own ApiKey.rateLimit,
# when set, overrides MCP_RATE_LIMIT_MAX for that key.
MCP_RATE_LIMIT_MAX=600
MCP_RATE_LIMIT_WINDOW_MS=60000
# Pre-auth per-IP limit (requests/window) — protects Postgres from invalid-key floods.
MCP_IP_RATE_LIMIT=120
# Reject request bodies larger than this many bytes with 413.
MCP_MAX_BODY_BYTES=4000000
# Abort a hung MCP request after this long and answer 504.
MCP_REQUEST_TIMEOUT_MS=60000

# --- Rate limiting (REST, fixed window). Backend: memory (per-process) or redis (shared). ---
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_BACKEND=memory

# --- HTTP hardening (REST API) ---
# Behind the host nginx — keep `true` so rate limiting keys on the real client IP (X-Forwarded-For).
TRUST_PROXY=true
# When set, GET /metrics requires `Authorization: Bearer <token>`; unset leaves it open (scrape from host).
# METRICS_TOKEN=
# CSV allowlist of CORS origins. Empty = CORS disabled (web + API are same-origin behind nginx).
CORS_ORIGINS=

# --- Indexing ---
# Total byte budget for file contents in one upload-and-index request (default 50 MB).
INDEX_UPLOAD_MAX_TOTAL_BYTES=52428800
# Staging dir the API writes uploaded files into for the worker to index (then delete). In Docker
# this is a volume shared with the workers container (compose sets it to /var/lib/brain-dock/staging).
# INDEX_STAGING_DIR=/var/lib/brain-dock/staging
# Allow reindexing repositories by server-side filesystem path (POST /repositories/:id/reindex).
# Defaults: true outside production, false in production (hosted users index via upload).
# INDEX_SERVER_PATHS=false

# --- Tracing (opt-in). none=off (default) | console=print spans | otlp=export to collector. ---
OTEL_TRACES_EXPORTER=none
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=brain-dock-api
