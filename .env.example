# brain-dock — environment template. Copy to .env and adjust. Validated by Zod at boot.

# Runtime
NODE_ENV=development
API_PORT=3000
LOG_LEVEL=info

# PostgreSQL (matches docker-compose.yml; non-default host ports to avoid local conflicts)
DATABASE_URL=postgresql://brain_dock:brain_dock@localhost:15432/brain_dock?schema=public

# Redis (BullMQ)
REDIS_URL=redis://localhost:16379

# Qdrant
QDRANT_URL=http://localhost:16333

# Ollama (embeddings)
OLLAMA_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
# Embedding provider — keep consistent across API/MCP/workers writing the same collections
EMBEDDER=deterministic

# Rate limiting (fixed window)
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000

# Auth — REPLACE these secrets in any real environment
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
